#!/bin/bash
# Runs after MessageManager.pkg installs the app into /Applications.
# Installs Python 3.12+ (if needed) and app pip dependencies for the console user.
set -uo pipefail

APP="/Applications/MessageManager.app"
APP_RESOURCES="${APP}/Contents/Resources/app"
REQUIREMENTS="${APP_RESOURCES}/requirements.txt"
ID="com.srtviperjr.messagemanager"

# Prefer the logged-in console user (installer runs as root).
CONSOLE_USER="$(stat -f '%Su' /dev/console 2>/dev/null || true)"
if [[ -z "${CONSOLE_USER}" || "${CONSOLE_USER}" == "root" || "${CONSOLE_USER}" == "loginwindow" ]]; then
  CONSOLE_USER="${USER:-}"
fi
if [[ -z "${CONSOLE_USER}" || "${CONSOLE_USER}" == "root" ]]; then
  CONSOLE_USER="$(basename "$(dscl . -list /Users UniqueID | awk '$2 >= 500 {print $1; exit}')" 2>/dev/null || true)"
fi
CONSOLE_HOME="$(dscl . -read "/Users/${CONSOLE_USER}" NFSHomeDirectory 2>/dev/null | awk '{print $2}')"
if [[ -z "${CONSOLE_HOME}" || ! -d "${CONSOLE_HOME}" ]]; then
  CONSOLE_HOME="/Users/${CONSOLE_USER}"
fi

APP_SUPPORT="${CONSOLE_HOME}/Library/Application Support/MessageManager"
LOG_DIR="${APP_SUPPORT}/logs"
DATA_DIR="${APP_SUPPORT}/data"
CATEGORIES_DB="${DATA_DIR}/categories.db"
mkdir -p "${LOG_DIR}" "${DATA_DIR}" "${DATA_DIR}/backups" 2>/dev/null || true
# CRITICAL: never delete or overwrite ${DATA_DIR}/categories.db or ${DATA_DIR}/backups.
# Conversation categories are the user's most important MessageManager data and must
# survive every pkg upgrade. This script only creates directories / fixes ownership.
if [[ -f "${CATEGORIES_DB}" ]]; then
  # Snapshot before an upgrade install so a bad future change can be rolled back.
  stamp="$(date -u '+%Y%m%dT%H%M%SZ')"
  cp -p "${CATEGORIES_DB}" "${DATA_DIR}/backups/categories-${stamp}-pre-pkg-install.db" 2>/dev/null || true
fi
# Ensure the console user owns Application Support data created by root.
if [[ -n "${CONSOLE_USER}" && "${CONSOLE_USER}" != "root" ]]; then
  chown -R "${CONSOLE_USER}:staff" "${APP_SUPPORT}" 2>/dev/null || true
fi
LOG="${LOG_DIR}/install.log"

log() {
  local line="[$(date '+%Y-%m-%d %H:%M:%S')] $*"
  echo "${line}" >>"${LOG}" 2>/dev/null || true
  echo "${line}"
}

python_usable() {
  local candidate="$1"
  [[ -n "${candidate}" && -x "${candidate}" ]] || return 1
  "${candidate}" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 9) else 1)' >/dev/null 2>&1
}

find_framework_python() {
  local candidates=(
    "/Library/Frameworks/Python.framework/Versions/3.13/bin/python3"
    "/Library/Frameworks/Python.framework/Versions/3.12/bin/python3"
    "/Library/Frameworks/Python.framework/Versions/3.11/bin/python3"
    "/Library/Frameworks/Python.framework/Versions/3.10/bin/python3"
    "/Library/Frameworks/Python.framework/Versions/3.9/bin/python3"
  )
  local c
  for c in "${candidates[@]}"; do
    if python_usable "${c}"; then
      echo "${c}"
      return 0
    fi
  done
  return 1
}

find_python() {
  local c
  if c="$(find_framework_python)"; then
    echo "${c}"
    return 0
  fi
  for c in "/opt/homebrew/bin/python3" "/usr/local/bin/python3" "/usr/bin/python3"; do
    if python_usable "${c}"; then
      echo "${c}"
      return 0
    fi
  done
  return 1
}

install_python_runtime() {
  # Official python.org macOS installer (universal2). Requires network during setup.
  local version="3.12.10"
  local pkg_name="python-${version}-macos11.pkg"
  local url="https://www.python.org/ftp/python/${version}/${pkg_name}"
  local tmp
  tmp="$(mktemp -d /tmp/messagemanager-python.XXXXXX)"
  local pkg_path="${tmp}/${pkg_name}"

  log "Downloading Python ${version} from python.org…"
  if ! curl -fsSL --connect-timeout 20 --max-time 300 -o "${pkg_path}" "${url}"; then
    log "ERROR: failed to download ${url}"
    rm -rf "${tmp}"
    return 1
  fi

  log "Installing Python ${version} system-wide…"
  if ! installer -pkg "${pkg_path}" -target / >>"${LOG}" 2>&1; then
    log "ERROR: installer failed for ${pkg_path}"
    rm -rf "${tmp}"
    return 1
  fi
  rm -rf "${tmp}"
  log "Python ${version} installed"
  # python.org builds need their certificate bundle for HTTPS (update checks).
  local cert_cmd="/Applications/Python ${version%.*}/Install Certificates.command"
  if [[ -f "${cert_cmd}" ]]; then
    log "Installing Python SSL certificates via ${cert_cmd}"
    bash "${cert_cmd}" >>"${LOG}" 2>&1 || true
  fi
  return 0
}

setup_venv_and_deps() {
  local system_python="$1"
  local venv="${APP_SUPPORT}/venv"
  local py=""

  log "Preparing venv for user ${CONSOLE_USER} with ${system_python}"

  run_as_user() {
    if [[ -n "${CONSOLE_USER}" && "${CONSOLE_USER}" != "root" ]] && id "${CONSOLE_USER}" >/dev/null 2>&1; then
      # shellcheck disable=SC2086
      su - "${CONSOLE_USER}" -c "$*"
    else
      bash -lc "$*"
    fi
  }

  # Create / refresh venv as the console user so ownership is correct.
  if ! run_as_user "\"${system_python}\" -m venv \"${venv}\"" >>"${LOG}" 2>&1; then
    log "WARN: venv creation failed; trying as root then chown"
    rm -rf "${venv}"
    if ! "${system_python}" -m venv "${venv}" >>"${LOG}" 2>&1; then
      log "ERROR: could not create venv"
      return 1
    fi
    chown -R "${CONSOLE_USER}:staff" "${venv}" 2>/dev/null || true
  fi

  py="${venv}/bin/python"
  if ! python_usable "${py}"; then
    log "ERROR: venv python not usable at ${py}"
    return 1
  fi

  if [[ ! -f "${REQUIREMENTS}" ]]; then
    log "WARN: requirements.txt missing at ${REQUIREMENTS}"
    return 0
  fi

  log "Installing Python packages from requirements.txt…"
  if ! run_as_user "\"${py}\" -m pip install --upgrade pip" >>"${LOG}" 2>&1; then
    "${py}" -m pip install --upgrade pip >>"${LOG}" 2>&1 || true
  fi
  if ! run_as_user "\"${py}\" -m pip install -r \"${REQUIREMENTS}\"" >>"${LOG}" 2>&1; then
    if ! "${py}" -m pip install -r "${REQUIREMENTS}" >>"${LOG}" 2>&1; then
      log "ERROR: pip install failed"
      return 1
    fi
    chown -R "${CONSOLE_USER}:staff" "${venv}" 2>/dev/null || true
  fi
  log "Python packages installed"
  return 0
}

log "postinstall starting (user=${CONSOLE_USER}, home=${CONSOLE_HOME})"

if [[ ! -d "${APP}" ]]; then
  log "ERROR: ${APP} was not installed"
  exit 1
fi

# Normalize ownership/permissions so Finder / Launchpad list the app.
chown -R root:wheel "${APP}" 2>/dev/null || true
chmod -R u+rwX,go+rX "${APP}" 2>/dev/null || true
chmod +x "${APP}/Contents/MacOS/MessageManager" 2>/dev/null || true
xattr -cr "${APP}" 2>/dev/null || true

# Force Launch Services to index /Applications (fixes missing Applications list entry
# when an older relocatable copy lived elsewhere, e.g. project dist/).
LSREGISTER="/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister"
if [[ -x "${LSREGISTER}" ]]; then
  "${LSREGISTER}" -f "${APP}" >/dev/null 2>&1 || true
  log "Registered ${APP} with Launch Services"
fi

# Touch Applications so Finder refreshes.
touch /Applications >/dev/null 2>&1 || true

# Prefer python.org Framework Python for Full Disk Access reliability.
# /usr/bin/python3 (CLT) can run the app but often cannot read chat.db even when
# MessageManager itself has Full Disk Access.
PYTHON_BIN=""
if PYTHON_BIN="$(find_framework_python)"; then
  log "Found Framework Python: ${PYTHON_BIN} ($("${PYTHON_BIN}" -V 2>&1))"
else
  log "No python.org Framework Python found; installing from python.org"
  if install_python_runtime; then
    hash -r 2>/dev/null || true
    if PYTHON_BIN="$(find_framework_python)"; then
      log "Using newly installed Python: ${PYTHON_BIN}"
    else
      log "ERROR: Python install finished but Framework python3 still not found"
      PYTHON_BIN="$(find_python || true)"
    fi
  else
    log "ERROR: automatic Python install failed; falling back to any usable python3"
    PYTHON_BIN="$(find_python || true)"
  fi
fi

DEPS_OK=0
if [[ -n "${PYTHON_BIN}" ]]; then
  if setup_venv_and_deps "${PYTHON_BIN}"; then
    DEPS_OK=1
  fi
fi

# Do not open Finder / Applications from postinstall while Installer.app is still
# showing its success dialog — that raced the UI and created a transient Dock tile
# on the right. Instead: delete the downloaded pkg now, then relaunch only after
# Installer exits, always via /Applications/MessageManager.app.

CACHE_DB="${CONSOLE_HOME}/Library/Application Support/MessageManager/messages-cache/chat.db"
FIRST_INSTALL=0
if [[ ! -f "${CACHE_DB}" ]]; then
  FIRST_INSTALL=1
fi

cleanup_downloaded_pkgs() {
  # Install already succeeded — remove the updater pkg without asking.
  local home="${CONSOLE_HOME}"
  local patterns=(
    "${home}/Downloads/MessageManager.pkg"
    "${home}/Downloads/MessageManager"*.pkg
    "${home}/Desktop/MessageManager.pkg"
    "${home}/Desktop/MessageManager"*.pkg
  )
  local f
  for f in "${patterns[@]}"; do
    # shellcheck disable=SC2086
    rm -f ${f} 2>/dev/null || true
  done
  if [[ -n "${CONSOLE_USER}" && "${CONSOLE_USER}" != "root" ]]; then
    su - "${CONSOLE_USER}" -c 'rm -f "${HOME}/Downloads/MessageManager.pkg" "${HOME}/Downloads"/MessageManager*.pkg "${HOME}/Desktop/MessageManager.pkg" "${HOME}/Desktop"/MessageManager*.pkg' >/dev/null 2>&1 || true
  fi
  log "Removed downloaded MessageManager.pkg from Downloads/Desktop (if present)"
}

# Help Launch Services / Dock keep a single identity for /Applications.
if [[ -x "${LSREGISTER}" ]]; then
  for stale in \
    "${CONSOLE_HOME}/Downloads/MessageManager.app" \
    "${CONSOLE_HOME}/Desktop/MessageManager.app"
  do
    if [[ -d "${stale}" ]]; then
      "${LSREGISTER}" -u "${stale}" >/dev/null 2>&1 || true
      log "Unregistered stale app copy: ${stale}"
    fi
  done
  "${LSREGISTER}" -f "${APP}" >/dev/null 2>&1 || true
fi

cleanup_downloaded_pkgs

schedule_after_installer() {
  # Write a small helper, then run it in the background as the console user.
  # It waits until Installer.app exits (user closed the success dialog), then
  # opens /Applications/MessageManager.app so Dock pins keep one identity.
  local mode="$1" # upgrade | first
  local runner="${CONSOLE_USER}"
  local helper_dir="${CONSOLE_HOME}/Library/Application Support/MessageManager/bin"
  local helper="${helper_dir}/finish-install.sh"
  mkdir -p "${helper_dir}" 2>/dev/null || true

  cat >"${helper}" <<EOF
#!/bin/bash
set +e
APP="/Applications/MessageManager.app"
MODE="${mode}"
DEPS_OK="${DEPS_OK}"

# Wait for Installer UI to finish (up to ~10 minutes).
for _ in \$(seq 1 1200); do
  if ! /usr/bin/pgrep -x Installer >/dev/null 2>&1; then
    break
  fi
  /bin/sleep 0.5
done
/bin/sleep 0.4

/usr/bin/osascript -e 'tell application "MessageManager" to quit' >/dev/null 2>&1 || true
/bin/sleep 0.4

if [[ "\${MODE}" == "first" ]]; then
  /usr/bin/open "x-apple.systempreferences:com.apple.settings.PrivacySecurity.extension?Privacy_AllFiles" >/dev/null 2>&1 \\
    || /usr/bin/open "x-apple.systempreferences:com.apple.preference.security?Privacy_AllFiles" >/dev/null 2>&1 \\
    || true
  DEPS_NOTE="Python packages were prepared for first launch."
  if [[ "\${DEPS_OK}" != "1" ]]; then
    DEPS_NOTE="If launch fails, install Python 3.9+ from python.org, then reopen MessageManager."
  fi
  /usr/bin/osascript >/dev/null 2>&1 <<APPLESCRIPT || true
display dialog "MessageManager is installed.

Enable Full Disk Access for MessageManager (Privacy & Security), then click Open.

\${DEPS_NOTE}" buttons {"Open MessageManager"} default button "Open MessageManager" with title "MessageManager Setup"
try
  do shell script "open '/Applications/MessageManager.app'"
end try
APPLESCRIPT
else
  /usr/bin/open "/Applications/MessageManager.app" >/dev/null 2>&1 || true
fi

/bin/rm -f "\${HOME}/Downloads/MessageManager.pkg" "\${HOME}/Downloads"/MessageManager*.pkg 2>/dev/null || true
/bin/rm -f "\${HOME}/Desktop/MessageManager.pkg" "\${HOME}/Desktop"/MessageManager*.pkg 2>/dev/null || true
/bin/rm -f "\${HOME}/Library/Application Support/MessageManager/bin/finish-install.sh" 2>/dev/null || true
EOF
  chmod 755 "${helper}" 2>/dev/null || true
  if [[ -n "${runner}" && "${runner}" != "root" ]]; then
    chown "${runner}:staff" "${helper}" 2>/dev/null || true
    chown -R "${runner}:staff" "${helper_dir}" 2>/dev/null || true
  fi

  if [[ -n "${runner}" && "${runner}" != "root" ]] && id "${runner}" >/dev/null 2>&1; then
    su - "${runner}" -c "nohup /bin/bash '${helper}' >/dev/null 2>&1 &" >/dev/null 2>&1 || true
  else
    nohup /bin/bash "${helper}" >/dev/null 2>&1 &
  fi
}

if [[ "${FIRST_INSTALL}" -eq 1 ]]; then
  log "First install — will prompt for Full Disk Access after Installer closes"
  schedule_after_installer "first"
else
  log "Upgrade install — will reopen /Applications/MessageManager.app after Installer closes"
  schedule_after_installer "upgrade"
fi

log "postinstall finished"
exit 0
